{
  "name": "@pet-crypto/mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "MCP server: stdio entry + minimal Fastify host for streamable HTTP (/mcp, /healthz).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "keygen": "tsx src/keygen.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@pet-crypto/core": "workspace:*",
    "@pet-crypto/db": "workspace:*",
    "@pet-crypto/mcp-tools": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "pg": "^8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.0.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
