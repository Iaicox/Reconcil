# Copy to .env and fill in. Inside compose, DATABASE_URL and REDIS_URL are
# derived automatically — the values below matter for local development only.

# Postgres password for the compose stack
POSTGRES_PASSWORD=change-me

# Streamable HTTP port (mcp-server)
PORT=8484

# Single self-host tenant (P10, ADR-012). The stdio server resolves and creates it
# on boot; HTTP bearer keys are minted per tenant with the keygen script, never via
# env (the plaintext is shown once):
#   pnpm --filter @pet-crypto/mcp-server exec tsx src/keygen.ts self-host
SELF_HOST_TENANT_SLUG=self-host

# Encryption key for integration credentials at rest (P9). Generate with:
#   openssl rand -hex 32
MASTER_KEY=

# Chain data providers (worker only; ADR-009). Never needed in CI — tests
# replay recorded fixtures.
ETHERSCAN_API_KEY=

# Price providers (worker only; ADR-007). DefiLlama and ECB are keyless; a
# CoinGecko demo key raises rate limits for the secondary source. Optional.
COINGECKO_API_KEY=

# Local development outside compose:
# DATABASE_URL=postgres://postgres:change-me@localhost:5432/pet_crypto
# REDIS_URL=redis://localhost:6379
